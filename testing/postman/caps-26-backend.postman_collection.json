  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET Health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Response has status ok\", function () {",
                  "  var data = pm.response.json();",
                  "  pm.expect(data.status).to.eql(\"ok\");",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "AOD",
      "item": [
        {
          "name": "GET AOD Polygon (Yesterday)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/v1/aod/polygon/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "aod",
                "polygon",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200 or 404\", function () {",
                  "  pm.expect([200, 404]).to.include(pm.response.code);",
                  "});",
                  "if (pm.response.code === 200) {",
                  "  var data = pm.response.json();",
                  "  pm.test(\"GeoJSON FeatureCollection\", function () {",
                  "    pm.expect(data.type).to.eql(\"FeatureCollection\");",
                  "    pm.expect(Array.isArray(data.features)).to.be.true;",
                  "  });",
                  "}"
                ]
              }
            }
          ]
        },
        {
